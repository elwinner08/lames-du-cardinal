{{!-- TAB: INVENTAIRE --}}
<section class="tab {{tab.cssClass}}" data-group="primary" data-tab="inventaire">
  <h3>{{localize "LAMES.ItemTypes.possession"}}
    <a data-action="itemCreate" data-type="possession"><i class="fas fa-plus"></i></a>
  </h3>
  <div class="item-list">
    {{#each possessions}}
    <div class="item has-tooltip" data-item-id="{{this._id}}">
      <span class="item-name">{{this.name}}</span>
      <span class="item-detail">{{localize "LAMES.Possession.cout"}} : {{this.system.cout}}</span>
      <div class="item-controls">
        <a data-action="itemEdit"><i class="fas fa-edit"></i></a>
        <a data-action="itemDelete"><i class="fas fa-trash"></i></a>
      </div>
      <div class="item-tooltip">
        {{{this.enrichedDescription}}}
        {{#if this.enrichedEffets}}<hr/><strong>{{localize "LAMES.Possession.effets"}} :</strong> {{{this.enrichedEffets}}}{{/if}}
      </div>
    </div>
    {{/each}}
  </div>

  <h3>{{localize "LAMES.ItemTypes.equipement"}}
    <a data-action="itemCreate" data-type="equipement"><i class="fas fa-plus"></i></a>
  </h3>
  <div class="item-list">
    {{#each equipements}}
    <div class="item" data-item-id="{{this._id}}">
      <span class="item-name">{{this.name}}</span>
      <span class="item-detail">x{{this.system.quantite}}</span>
      <div class="item-controls">
        <a data-action="itemEdit"><i class="fas fa-edit"></i></a>
        <a data-action="itemDelete"><i class="fas fa-trash"></i></a>
      </div>
    </div>
    {{/each}}
  </div>
</section>
